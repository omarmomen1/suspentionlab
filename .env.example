# SuspensionLab — Production Environment Variables
# Copy to .env and fill in real values before deploying.
# NEVER commit this file with real secrets.

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://susplab:CHANGEME@localhost:5432/suspensionlab
POSTGRES_PASSWORD=CHANGEME

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://:CHANGEME@localhost:6379/0
REDIS_PASSWORD=CHANGEME

# ─── Auth ────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=GENERATE_A_RANDOM_64_CHAR_HEX_STRING_HERE

# ─── Lemon Squeezy ───────────────────────────────────────────────────────────
# Get from Settings > API in Lemon Squeezy
LEMON_SQUEEZY_API_KEY=eyJ...
# Get from Settings > Webhooks
LEMON_SQUEEZY_WEBHOOK_SECRET=your_secret_here
# Get from Store Settings
LEMON_SQUEEZY_STORE_ID=12345
# Get from Products > Variants
LEMON_PRO_VARIANT_ID=11111
LEMON_ENTERPRISE_VARIANT_ID=22222

# ─── URLs ────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://app.suspensionlab.io
ENVIRONMENT=PROD

# ─── Frontend (Next.js) — exposed to the browser ─────────────────────────────
# These are baked in at build time for the Docker image
NEXT_PUBLIC_API_URL=https://api.suspensionlab.io
# Leave blank in production — users auth with JWT, no shared key needed
NEXT_PUBLIC_API_KEY=
